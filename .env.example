# Copy to .env.local for development. In Vercel: Project → Settings → Environment Variables.

# --- Supabase (required for persistence, invites, uploads) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this deployment — used in invite emails (must match production domain).
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenAI (poster analysis) ---
OPENAI_API_KEY=

# --- Resend (transactional email) ---
# API key and verified domain must be from the SAME Resend project (Dashboard → Domains).
# RESEND_FROM must use that domain, e.g. RSVP <invite@yourdomain.com> (domain part is normalized to lowercase).
RESEND_API_KEY=
RESEND_FROM=Memento <onboarding@resend.dev>

# Optional: set a random secret, redeploy, then GET /api/resend-debug with header Authorization: Bearer <secret>
# to see which domains this API key can use and whether RESEND_FROM matches (diagnoses "domain not verified").
RESEND_DEBUG_SECRET=
